{
  "name": "pw-ss-pp",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:auth": "playwright test tests/auth.spec.ts",
    "test:guest": "playwright test tests/guest.spec.ts",
    "test:concurrency": "playwright test tests/concurrency.spec.ts",
    "test:api": "playwright test tests/api.spec.ts",
    "test:report": "playwright show-report pw-report-html",
    "app:start": "node site/server.js",
    "dashboard:api:start": "node dashboard-server.js",
    "dashboard:ui:start": "http-server dashboard -p 3001",
    "dev:local": "concurrently \"npm run app:start\" \"npm run dashboard:api:start\" \"npm run dashboard:ui:start\"",
    "dev:docker": "docker-compose up -d",
    "dev:docker:stop": "docker-compose down",
    "dev:docker:logs": "docker-compose logs -f",
    "k8s:minikube:start": "minikube start --driver=docker --memory=4096",
    "k8s:minikube:stop": "minikube stop",
    "k8s:build": "docker build -t pw-ss-pp:latest . && docker build -f Dockerfile.dashboard -t pw-ss-pp:dashboard:latest .",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:deploy:status": "kubectl get pods && kubectl get svc",
    "k8s:cleanup": "kubectl delete all --all",
    "k8s:logs": "kubectl logs -f deployment/dashboard-api",
    "port:kill:3000": "npx kill-port 3000",
    "port:kill:3001": "npx kill-port 3001",
    "port:kill:4000": "npx kill-port 4000",
    "port:kill:all": "npm run port:kill:3000 && npm run port:kill:3001 && npm run port:kill:4000"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.1.0",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "kill-port": "^2.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "body-parser": "^1.20.4",
    "dockerode": "^4.0.0",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.3.2",
    "playwright": "^1.58.2",
    "moment": "^2.29.4",
    "pretty-ms": "^9.1.0",
    "swagger-ui-express": "^4.6.3",
    "tslog": "^4.10.2",
    "ws": "^8.14.2"
  }
}
